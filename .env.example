# Copy this to .env for local dev if you want (optional — the app works fine without it locally).
# On Vercel, set these under Project Settings → Environment Variables.

# Any long random string — this is what signs your login cookies. Make one up, keep it secret.
JWT_SECRET=change-this-to-something-long-and-random

# NOT needed locally, NOT something you type in yourself.
# These two get added AUTOMATICALLY once you connect the Upstash Redis integration
# in your Vercel project's Storage tab. Just here so you know what they are.
# KV_REST_API_URL=
# KV_REST_API_TOKEN=
